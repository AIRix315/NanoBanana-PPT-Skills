##############################################################################
# RH-PPT-Skill - 环境变量配置文件
##############################################################################
#
# 📋 使用说明：
#
# 1. 复制此文件为 .env
#    cp .env.example .env
#
# 2. 将 your-api-key-here 替换为您的实际 API 密钥
#
# 3. .env 文件不会被提交到 Git（已在 .gitignore 中配置）
#
##############################################################################

##############################################################################
# 🔑 RunningHub 双 Key 配置体系
##############################################################################
#
# RunningHub 平台提供两种 API Key 类型：
#
# 1. 企业级 API Key (Enterprise Key)
#    - 特点：高并发支持（100并发）、按时长计费
#    - 适用：批量生产、商业用途、高并发生成
#    - 获取地址：https://www.runninghub.cn/enterprise-api/sharedApi
#    - 用于模型：全能图片PRO/V2（图像生成）
#
# 2. 创作级 API Key (Creator Key)
#    - 特点：消耗RH币、与网站共享并发
#    - 适用：个人创作、测试、低频使用
#    - 获取地址：https://www.runninghub.cn/enterprise-api/consumerApi
#    - 用于模型：Seedance、LTX-2.3、可灵等视频生成模型
#
# 💡 如果只有一个 Key，可以只配置 RH_API_KEY，系统会自动回退使用
#
##############################################################################

##############################################################################
# 🖼️ 图像生成 API Key（企业级）
##############################################################################

# 企业级 API Key - 用于图像生成
# 模型：全能图片PRO/V2 (Gemini 3 Pro/Flash)
# 特点：高并发、按时长计费、适合批量生产
# 获取：https://www.runninghub.cn/enterprise-api/sharedApi
RH_ENTERPRISE_KEY=your-enterprise-api-key-here

# 备用：通用 API Key（兼容模式）
# 如果未配置 RH_ENTERPRISE_KEY，将使用此 Key
# 可用于同时支持图像和视频生成的场景
RH_API_KEY=your-general-api-key-here

##############################################################################
# 🎬 视频生成 API Key（创作级）
##############################################################################

# 创作级 API Key - 用于视频生成
# 模型：Seedance 2.0、LTX-2.3、可灵O1等
# 特点：消耗RH币、适合个人创作和测试
# 获取：https://www.runninghub.cn/enterprise-api/consumerApi
RH_CREATOR_KEY=your-creator-api-key-here

##############################################################################
# 🎥 可灵 AI 直连密钥（可选，已弃用）
##############################################################################
# 
# 注意：现在视频生成已统一通过 RunningHub API 调用
# 以下密钥仅用于特殊场景的直连调用（不推荐）
#
# KLING_ACCESS_KEY=your-kling-access-key-here
# KLING_SECRET_KEY=your-kling-secret-key-here

##############################################################################
# 📝 配置示例
##############################################################################
#
# 场景1：只有企业级 Key（推荐）
#   RH_ENTERPRISE_KEY=enterprise-xxx
#   RH_CREATOR_KEY=  # 留空，视频功能将无法使用
#   RH_API_KEY=      # 留空
#
# 场景2：只有创作级 Key
#   RH_ENTERPRISE_KEY=
#   RH_CREATOR_KEY=creator-xxx
#   RH_API_KEY=
#
# 场景3：双 Key 配置（最佳）
#   RH_ENTERPRISE_KEY=enterprise-xxx  # 图像生成
#   RH_CREATOR_KEY=creator-xxx         # 视频生成
#   RH_API_KEY=
#
# 场景4：单 Key 兼容模式
#   RH_API_KEY=general-xxx  # 同时用于图像和视频
#   RH_ENTERPRISE_KEY=
#   RH_CREATOR_KEY=
#
##############################################################################

##############################################################################
# ⚙️ 高级配置（可选）
##############################################################################

# 默认图像模型（v2 或 pro）
#DEFAULT_IMAGE_MODEL=pro

# 默认视频提供者（kling, seedance, ltx）
#DEFAULT_VIDEO_PROVIDER=seedance

# 最大并发数限制
#MAX_CONCURRENT_TASKS=3

# 视频生成超时（秒）
#VIDEO_TIMEOUT=600

##############################################################################
# 🛡️ 安全提醒
##############################################################################
#
# ⚠️  永远不要将 .env 文件提交到 Git 仓库！
# ⚠️  永远不要在代码中硬编码 API 密钥！
# ⚠️  永远不要在公开场合分享你的 API 密钥！
#
# ✅ .env 文件已在 .gitignore 中配置，不会被 Git 跟踪
# ✅ 使用 .env.example 作为模板，保护真实密钥
# ✅ 定期检查密钥是否泄露
#
##############################################################################

